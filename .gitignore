# Unity generated
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs

# JetBrains
.idea/

# macOS / Windows
.DS_Store
Thumbs.db

# Claude Code (entire folder)
.claude/

# Unity auto-generated
*.pidb
*.pdb
*.mdb
sysinfo.txt

# Firebase large binaries (>100MB - use Git LFS or reinstall via SDK)
Assets/Firebase/Plugins/x86_64/FirebaseCppApp*.bundle
Assets/Firebase/Plugins/x86_64/FirebaseCppApp*.so

# Unity packages / archives in Assets (should be installed via Package Manager)
Assets/*.unitypackage
Assets/*.zip
Assets/*.rar
Assets/*.7z

# PDF documentation
Assets/**/*.pdf

# Screenshots (runtime captures, not source assets)
Assets/Screenshots/

# Firebase editor executables (platform tools, not source)
Assets/Firebase/Editor/*.exe
Assets/ExternalDependencyManager/Editor/**/*.exe

# OS / editor temp
*.stackdump
crashlytics-build.properties
